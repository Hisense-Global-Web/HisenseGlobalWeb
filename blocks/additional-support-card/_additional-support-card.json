{
  "definitions": [
    {
      "title": "Additional Support Card",
      "id": "additional-support-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Additional Support Card",
              "model": "additional-support-card",
              "classes": "additional-support-card",
              "filter": "additional-support-card",
              "pc_numberColumns": 4
            }
          }
        }
      }
    },
    {
      "title": "Additional Support Card Item",
      "id": "additional-support-card-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Additional Support Card Item",
              "model": "additional-support-card-item",
              "cirlce-style": "none",
              "button-display": "pc-and-mobile",
              "button-style": "white",
              "button-action": "pageRedirect"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "additional-support-card",
      "fields": [
        {
          "component": "number",
          "name": "pc_numberColumns",
          "label": "PC: Items per row",
          "valueType": "number",
          "description": "For PC: Number of columns displayed per row."
        }
      ]
    },
    {
      "id": "additional-support-card-item",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "SVG icon",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "subtitle",
          "label": "Subtitle",
          "valueType": "string"
        },
        {
          "component": "container",
          "name": "officehours-container",
          "label": "Office Hours Container",
          "valueType": "string",
          "collapsible": true,
          "fields": [
            {
              "component": "text",
              "name": "office_hours1",
              "label": "Office Hours 1",
              "valueType": "string"
            },
            {
              "component": "text",
              "name": "office_hours2",
              "label": "Office Hours 2",
              "valueType": "string"
            },
            {
              "component": "text",
              "name": "office_hours3",
              "label": "Office Hours 3",
              "valueType": "string"
            },
            {
              "component": "text",
              "name": "office_hours4",
              "label": "Office Hours 4",
              "valueType": "string"
            },
            {
              "component": "text",
              "name": "office_hours5",
              "label": "Office Hours 5",
              "valueType": "string"
            },
            {
              "component": "text",
              "name": "office_hours6",
              "label": "Office Hours 6",
              "valueType": "string"
            },
            {
              "component": "text",
              "name": "office_hours7",
              "label": "Office Hours 7",
              "valueType": "string"
            }
          ]
        },
        {
          "component": "text",
          "name": "contact_information",
          "label": "Contact Information(Phone Number or Email)",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "button-action",
          "label": "Button Action",
          "valueType": "string",
          "options": [
            {
              "name": "Page Redirect",
              "value": "pageRedirect"
            },
            {
              "name": "Phone Call",
              "value": "phoneCall"
            },
            {
              "name": "Send Email",
              "value": "sendEmail"
            }
          ]
        },
        {
          "component": "text",
          "name": "button_text",
          "label": "Button Text",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "button-action"
              },
              "pageRedirect"
            ]
          }
        },
        {
          "component": "aem-content",
          "name": "button_link",
          "label": "Button Link",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "button-action"
              },
              "pageRedirect"
            ]
          }
        },
        {
          "component": "select",
          "name": "button-style",
          "label": "Button Style",
          "valueType": "string",
          "options": [
            {
              "name": "White",
              "value": "white"
            },
            {
              "name": "Green 60",
              "value": "green60"
            }
          ]
        },
        {
          "component": "select",
          "name": "button-display",
          "label": "Button Display Options",
          "valueType": "string",
          "options": [
            {
              "name": "Displayed on both PC and Mobile",
              "value": "pc-and-mobile"
            },
            {
              "name": "Only displayed on Mobile",
              "value": "mobile-only"
            }
          ]
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "additional-support-card",
      "components": [
        "additional-support-card-item"
      ]
    }
  ]
}