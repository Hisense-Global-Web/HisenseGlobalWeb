{
  "definitions": [
    {
      "title": "Headline",
      "id": "headline",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Headline",
              "model": "headline",
              "key-value": true,
              "data-source": "fill",
              "section-title": "Featured",
              "eyebrow": "PARTNERSHIPS & SPONSORSHIPS",
              "subtitle": "Hisense Accelerates ESG Strategy With AI-Driven Sustainability Milestones",
              "text": "QINGDAO, China, November 7, 2025 – Hisense, a leading brand in global consumer electronics and home appliances",
              "date": "Nov 7, 2025",
              "location": "Qingdao",
              "author": "Sarah Johnson",
              "cta-text": "Read now",
              "cta-link": "",
              "has-download": "true"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "headline",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "section-title",
          "label": "Section Title",
          "placeholder": "Featured"
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "multi": false
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "data-source",
          "label": "Data Source",
          "options": [
            { "name": "Fill", "value": "fill" },
            { "name": "Child Page", "value": "child-page" }
          ]
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "source-path",
          "label": "Source Path",
          "condition": { "===": [{ "var": "data-source" }, "child-page"] }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "eyebrow",
          "label": "Eyebrow",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "subtitle",
          "label": "Subtitle",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "text",
          "label": "Text",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "date",
          "label": "Date",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "location",
          "label": "Location",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "author",
          "label": "Author",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "cta-text",
          "label": "CTA Text",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "cta-link",
          "label": "CTA Link",
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        },
        {
          "component": "checkbox",
          "valueType": "boolean",
          "name": "has-download",
          "label": "Has Download",
          "value": false,
          "condition": { "===": [{ "var": "data-source" }, "fill"] }
        }
      ]
    }
  ],
  "filters": []
}
