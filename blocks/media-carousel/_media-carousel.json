{
  "definitions": [
    {
      "title": "Media Carousel",
      "id": "media-carousel",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Media Carousel",
              "model": "media-carousel",
              "filter": "media-carousel"
            }
          }
        }
      }
    },
    {
      "title": "Media Carousel Item",
      "id": "media-carouselItem",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Media Carousel Item",
              "model": "media-carouselItem",
              "mainContent": "image"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "media-carousel",
      "fields": [
        {
          "component": "select",
          "name": "block_classes",
          "value": "",
          "label": "Text Position",
          "description": "",
          "valueType": "string",
          "options": [
            {
              "name": "default(no text)",
              "value": ""
            },
            {
              "name": "overlay_text-left",
              "value": "left-style"
            },
            {
              "name": "overlay_text-left-bottom",
              "value": "left-bottom-style"
            },
            {
              "name": "media-top_text-left-bottom",
              "value": "bottom-left-style"
            },
            {
              "name": "overlay_text-bottom-center",
              "value": "center-style"
            },
            {
              "name": "media-top_text-center",
              "value": "bottom-center-style"
            }
          ]
        },
        {
          "component": "text",
          "name": "subtitle",
          "value": "",
          "label": "Colorful Text",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "title",
          "value": "",
          "label": "Title",
          "valueType": "string"
        }
      ]
    },
    {
      "id": "media-carouselItem",
      "fields": [
        {
          "component": "select",
          "name": "mainContent",
          "label": "Section Content Type",
          "options": [
            {
              "name": "Image(Default)",
              "value": "image"
            },
            {
              "name": "Video",
              "value": "video"
            }
          ]
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Image or Video",
          "multi": false
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "img",
          "label": "Img Snapshot For Video Loading",
          "condition": { "===": [{ "var": "mainContent" }, "video"] },
          "multi": false
        },
        {
          "component": "text",
          "name": "subtitle",
          "value": "",
          "label": "Subtitle",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "title",
          "value": "",
          "label": "Title",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "body",
          "value": "",
          "label": "Body Text",
          "valueType": "string"
        },
        {
          "component": "aem-content",
          "name": "button_link",
          "label": "Button Link",
          "condition": {
            "or" : [
              {"===":[{"var": "block_classes"}, "left-style"]},
              {"===":[{"var": "block_classes"}, "left-bottom-style"]}
            ]
          }
        },
        {
          "component": "text",
          "name": "button_label",
          "label": "Button Label",
          "condition":{"log": [{"var": "block_classes"}]}
        }
      ]
    }

  ],
  "filters": [
    {
      "id": "media-carousel",
      "components": [
        "media-carouselItem"
      ]
    }
  ]
}
