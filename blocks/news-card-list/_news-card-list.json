  "models": [
    {
      "id": "news-card-list",
      "fields": [
        {
          "component": "richtext",
          "name": "title",
          "label": "Section Title",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "page-size",
          "label": "Items per page",
          "description": "How many news cards to show per page.",
          "valueType": "number"
        },
        {
          "component": "richtext",
          "name": "empty-text",
          "label": "Empty Result Text",
          "description": "Text to show when no news items match the current filters.",
          "valueType": "string"
        },
        {
          "component": "boolean",
          "name": "should-paginated",
          "label": "Do you need paginated?",
          "valueType": "boolean"
        },
        {
          "component" : "text",
          "label" : "button",
          "name" : "paginated-btn-text",
          "valueType" : "string",
          "condition" : {
            "===" : [
              {
                "var" : "should-paginated"
              },
              false
            ]
          }
        }
      ]
    }
  ],
  "filters": []
