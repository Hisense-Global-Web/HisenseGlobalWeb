{
  "definitions": [
    {
      "title": "Press Release Card",
      "id": "press-release-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Press Release Card",
              "model": "press-release-card",
              "filter": "press-release-card",
              "key-value": true,
              "title": "Related Press Releases",
              "endpoint": "/us/en/newsroom.json",
              "page-size": "3",
              "empty-text": "No press releases found.",
              "should-paginated": false,
              "discover-all-link": "/us/en/company/newsroom"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "press-release-card",
      "fields": [
        {
          "component": "richtext",
          "name": "title",
          "label": "Section Title",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "endpoint",
          "label": "API Endpoint",
          "description": "The JSON endpoint to fetch press release data from.",
          "valueType": "string"
        },
        {
          "component": "aem-tag",
          "name": "filter-tags",
          "label": "Filter by Tags",
          "description": "Select tags to filter press releases. Leave empty to show all.",
          "valueType": "string",
          "multi": true,
          "rootPath": "/content/cq:tags/hisense"
        },
        {
          "component": "text",
          "name": "page-size",
          "label": "Items per page",
          "description": "How many press release cards to show.",
          "valueType": "number"
        },
        {
          "component": "richtext",
          "name": "empty-text",
          "label": "Empty Result Text",
          "description": "Text to show when no press releases found.",
          "valueType": "string"
        },
        {
          "component": "boolean",
          "name": "should-paginated",
          "label": "Enable Pagination",
          "valueType": "boolean"
        },
        {
          "component": "text",
          "name": "paginated-btn-text",
          "label": "Load More Button Text",
          "valueType": "string",
          "condition": {
            "===": [
              { "var": "should-paginated" },
              false
            ]
          }
        },
        {
          "component": "reference",
          "name": "discover-all-link",
          "label": "Discover All News Link",
          "description": "The link for the 'Discover all news' button.",
          "valueType": "string",
          "multi": false,
          "rootPath": "/content"
        }
      ]
    }
  ],
  "filters": []
}
