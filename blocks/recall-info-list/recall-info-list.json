{
  "definitions": [
    {
      "title": "Recall Info List",
      "id": "recall-info-list",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Recall Info List",
              "model": "recall-info-list",
              "key-value": true,
              "page-size": "9",
              "empty-text": "No recall information match your filters.",
              "should-paginated": true
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "recall-info-list",
      "fields": [
        {
          "component": "text",
          "name": "page-size",
          "label": "Items per page",
          "description": "How many recall information to show per page.",
          "valueType": "number"
        },
        {
          "component": "richtext",
          "name": "empty-text",
          "label": "Empty Result Text",
          "description": "Text to show when no news items match the current filters.",
          "valueType": "string"
        },
        {
          "component": "boolean",
          "name": "should-paginated",
          "label": "Do you need paginated?",
          "valueType": "boolean"
        },
        {
          "component": "text",
          "label": "button",
          "name": "paginated-btn-text",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "should-paginated"
              },
              false
            ]
          }
        }
      ]
    }
  ],
  "filters": []
}