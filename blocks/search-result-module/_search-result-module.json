        },
        {
          "component": "text",
          "valueType": "string",
          "name": "noResultSubtitle",
          "label": "No Result Subtitle"
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "noResultContent",
          "label": "No Result Richtext Content"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "popularSearchHeading",
          "label": "Popular Search Heading"
        },
        {
          "component": "aem-tag",
          "name": "popularSearchTags",
          "label": "Popular Search Tags",
          "rootPath": "/content/cq:tags/hisense"
        },
        {
          "component": "aem-content",
          "valueType": "string",
          "name": "popularSearchLink",
          "label": "Popular Search Link (search page URL)"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "prevButtonAriaLabel",
          "label": "Previous Button Aria Label"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "nextButtonAriaLabel",
          "label": "Next Button Aria Label"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "loadMoreLabel",
          "label": "Load More Button Label"
        }
      ]
    },
    {
      "id": "search-result-item",
