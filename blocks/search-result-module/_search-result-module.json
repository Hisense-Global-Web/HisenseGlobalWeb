        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Tab Title"
        },
        {
          "component": "select",
          "name": "type",
          "label": "Display Type",
          "options": [
            {
              "name": "Product",
              "value": "product"
            },
            {
              "name": "News",
              "value": "news"
            },
            {
              "name": "Blog",
              "value": "blog"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "number",
          "name": "pageSize",
          "label": "Page Size"
        }
      ]
    }
