{
  "definitions": [
    {
      "title": "Tech Items",
      "id": "tech-items",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Tech Items",
              "model": "tech-items",
              "classes": "tech-items-box",
              "item_title": "Item Title",
              "item_text": "Item text goes here."
