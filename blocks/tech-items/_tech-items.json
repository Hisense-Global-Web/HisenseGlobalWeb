              {
                "name": "Icon",
                "value": "icon-style"
              },
              {
                "name": "Stats",
                "value": "stats-style"
              }
          ]
        },
        {
          "component": "reference",
          "valueType": "string",
          "condition": { "===": [{"var" : "component-style"}, "icon-style"] },
          "name": "icon",
          "label": "Icon",
          "multi": false
        },
        {
          "component": "text",
          "name": "item_title",
          "label": "Title",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "item_text",
          "label": "Text",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": []
}
