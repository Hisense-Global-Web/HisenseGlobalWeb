[
  {
    "id": "main",
    "components": [
      "section",
      "popup-module",
      "navigation",
      "company-page-navigation",
      "support-navigation",
      "footerContainer",
      "search-box-navigation"
    ]
  },
  {
    "...": "./_section.json#/filters"
  },
  {
    "...": "./_popup-module.json#/filters"
  },
  {
    "...": "../blocks/*/_*.json#/filters"
  },
  {
    "id": "richtext",
    "rte": {
      "toolbar": {
        "format": ["bold", "italic", "underline", "strike"],
        "alignment": ["left", "center", "right", "justify"],
        "direction": ["rtl", "ltr"],
        "indentation": ["indent", "outdent"],
        "blocks": ["paragraph", "h1", "h2", "h3", "h4", "h5", "h6", "code_block"],
        "list": ["bullet_list", "ordered_list"],
        "insert": ["link", "unlink", "image"],
        "sr_script": ["superscript", "subscript"],
        "editor": ["removeformat"],
        "sections": ["format", "alignment", "list"]
      },
      "actions": {
        "bullet_list": {
          "wrapInParagraphs": true,
          "label": "Bullet List"
        },
        "ordered_list": {
          "wrapInParagraphs": false
        },
        "link": {
          "hideTarget": false,
          "label": "Add Link"
        },
        "unlink": {
          "label": "Remove Link"
        }
      }
    }
  }
]